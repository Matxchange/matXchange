  "html": "<style>\r\n@import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap');\r\n.rcpt{font-family:'Inter',-apple-system,sans-serif;max-width:340px;margin:0 auto;background:#fff;border:1px solid #E0E0DC}\r\n.rcpt-head{background:#1A1A1A;padding:14px 18px;display:flex;align-items:center;justify-content:space-between}\r\n.gold{height:3px;background:#C8932A}\r\n.rcpt-amt{background:#F9F9F7;padding:16px 18px;text-align:center;border-bottom:1px solid #E8E8E4}\r\n.rcpt-body{padding:14px 18px}\r\n.lbl{color:#888;font-size:11px}\r\n.val{color:#111;font-size:11px;font-weight:600;text-align:right}\r\n.row{display:flex;justify-content:space-between;padding:5px 0;border-bottom:1px solid #F5F5F3}\r\n.row:last-child{border-bottom:none}\r\n.section{font-size:8px;font-weight:700;color:#999;text-transform:uppercase;letter-spacing:0.12em;margin:10px 0 4px;display:block}\r\n.paid-badge{display:inline-block;padding:2px 8px;border-radius:20px;font-size:9px;font-weight:700;letter-spacing:0.04em;text-transform:uppercase}\r\n.paid{background:#F0FDF4;color:#166534;border:1px solid #BBF7D0}\r\n.unpaid{background:#FEF2F2;color:#991B1B;border:1px solid #FECACA}\r\n.rcpt-foot{background:#1A1A1A;padding:8px 18px;display:flex;justify-content:space-between}\r\n.chain{border:1px solid #E0E0DC;background:#FAFAF8;padding:8px 10px;margin:10px 0}\r\n.breakdown{background:#F9F9F7;border:1px solid #E8E8E4;padding:10px 12px;margin:8px 0}\r\n@media print{.rcpt{border:1px solid #ccc}}\r\n</style>\r\n\r\n<div class=\"rcpt\">\r\n\r\n<div class=\"rcpt-head\">\r\n  <div style=\"display:flex;align-items:center;gap:8px\">\r\n    <img src=\"/files/logo.png\" height=\"28\" alt=\"MatXchange\" style=\"display:block\">\r\n    <div>\r\n      <div style=\"color:#fff;font-size:11px;font-weight:600\">MatXchange Ltd</div>\r\n      <div style=\"color:#888;font-size:8px\">matxchange.co.ke</div>\r\n    </div>\r\n  </div>\r\n  <div style=\"text-align:right\">\r\n    <div style=\"color:#C8932A;font-size:8px;letter-spacing:0.1em;text-transform:uppercase;font-weight:600\">Receipt</div>\r\n    <div style=\"color:#888;font-size:8px;margin-top:1px\">{{ doc.transaction_date }}</div>\r\n  </div>\r\n</div>\r\n\r\n<div class=\"gold\"></div>\r\n\r\n<div class=\"rcpt-amt\">\r\n  <div style=\"font-size:8px;color:#999;text-transform:uppercase;letter-spacing:0.1em;margin-bottom:4px;font-weight:600\">Amount Paid</div>\r\n  <div style=\"font-size:32px;font-weight:700;color:#1A1A1A;letter-spacing:-1px;line-height:1\">KES {{ \"{:,.0f}\".format(doc.total_amount_kes) }}</div>\r\n  <div style=\"font-size:10px;color:#888;margin-top:4px\">via {{ doc.payment_method }}</div>\r\n  <div style=\"margin-top:8px\">\r\n    {% if doc.payment_status == \"Paid\" %}\r\n    <span class=\"paid-badge paid\">{{ doc.payment_status }}</span>\r\n    {% else %}\r\n    <span class=\"paid-badge unpaid\">{{ doc.payment_status }}</span>\r\n    {% endif %}\r\n  </div>\r\n</div>\r\n\r\n<div class=\"rcpt-body\">\r\n\r\n  <span class=\"section\">Transaction</span>\r\n  <div class=\"row\"><span class=\"lbl\">ID</span><span class=\"val\" style=\"font-family:monospace;font-size:10px\">{{ doc.name }}</span></div>\r\n  <div class=\"row\"><span class=\"lbl\">Date</span><span class=\"val\">{{ doc.transaction_date }}</span></div>\r\n  <div class=\"row\"><span class=\"lbl\">Picker</span><span class=\"val\">{{ doc.picker }}</span></div>\r\n  {% if doc.collector %}<div class=\"row\"><span class=\"lbl\">Collector</span><span class=\"val\">{{ doc.collector }}</span></div>{% endif %}\r\n  {% if doc.recycler %}<div class=\"row\"><span class=\"lbl\">Recycler</span><span class=\"val\">{{ doc.recycler }}</span></div>{% endif %}\r\n\r\n  <span class=\"section\">Material</span>\r\n  <div class=\"row\"><span class=\"lbl\">Category</span><span class=\"val\">{{ doc.waste_category }}</span></div>\r\n  <div class=\"row\"><span class=\"lbl\">Weight</span><span class=\"val\">{{ doc.quantity_kg }} kg</span></div>\r\n  <div class=\"row\"><span class=\"lbl\">Unit price</span><span class=\"val\">KES {{ doc.unit_price_kes }}/kg</span></div>\r\n\r\n  <span class=\"section\">Full breakdown — no hidden fees</span>\r\n  <div class=\"breakdown\">\r\n    <div style=\"display:flex;justify-content:space-between;padding:3px 0;font-size:11px\">\r\n      <span style=\"color:#666\">Material ({{ doc.quantity_kg }}kg × KES {{ doc.unit_price_kes }})</span>\r\n      <span style=\"color:#111;font-weight:600\">KES {{ \"{:,.0f}\".format(doc.total_amount_kes) }}</span>\r\n    </div>\r\n    <div style=\"display:flex;justify-content:space-between;padding:3px 0;font-size:11px\">\r\n      <span style=\"color:#666\">Platform fee</span>\r\n      <span style=\"color:#111;font-weight:600\">KES 0</span>\r\n    </div>\r\n    <div style=\"display:flex;justify-content:space-between;padding:3px 0;font-size:11px\">\r\n      <span style=\"color:#666\">Transaction fee</span>\r\n      <span style=\"color:#111;font-weight:600\">KES 0</span>\r\n    </div>\r\n    <div style=\"display:flex;justify-content:space-between;padding:3px 0;font-size:11px\">\r\n      <span style=\"color:#666\">VAT</span>\r\n      <span style=\"color:#111;font-weight:600\">KES 0</span>\r\n    </div>\r\n    <div style=\"display:flex;justify-content:space-between;padding:5px 0 2px;font-size:12px;border-top:1px solid #E0E0DC;margin-top:4px\">\r\n      <span style=\"color:#111;font-weight:700\">Picker receives</span>\r\n      <span style=\"color:#1A1A1A;font-weight:700\">KES {{ \"{:,.0f}\".format(doc.total_amount_kes) }}</span>\r\n    </div>\r\n    <div style=\"font-size:8px;color:#999;margin-top:6px;line-height:1.5\">Zero fees. Full value goes to the picker. No deductions.</div>\r\n  </div>\r\n\r\n  {% if doc.payment_reference %}\r\n  <span class=\"section\">Payment reference</span>\r\n  <div class=\"row\"><span class=\"lbl\">M-Pesa ref</span><span class=\"val\" style=\"font-family:monospace;font-size:10px\">{{ doc.payment_reference }}</span></div>\r\n  {% if doc.payment_date %}<div class=\"row\"><span class=\"lbl\">Paid on</span><span class=\"val\">{{ doc.payment_date }}</span></div>{% endif %}\r\n  {% endif %}\r\n\r\n  {% if doc.stellar_hash %}\r\n  <div class=\"chain\">\r\n    <div style=\"font-size:8px;font-weight:700;color:#666;text-transform:uppercase;letter-spacing:0.1em;margin-bottom:3px\">Blockchain proof</div>\r\n    <div style=\"font-family:monospace;font-size:8px;color:#444;word-break:break-all;line-height:1.4\">{{ doc.stellar_hash }}</div>\r\n  </div>\r\n  {% endif %}\r\n\r\n  <div style=\"font-size:8px;color:#999;line-height:1.5;text-align:center;border-top:1px solid #F0F0EC;padding-top:10px;margin-top:6px\">\r\n    Official MatXchange receipt.<br>\r\n    Disputes: hello@matxchange.co.ke within 24 hours.\r\n  </div>\r\n\r\n</div>\r\n\r\n<div class=\"rcpt-foot\">\r\n  <div style=\"color:#888;font-size:8px\">MatXchange Ltd · Nairobi</div>\r\n  <div style=\"color:#888;font-size:8px\">matxchange.co.ke</div>\r\n</div>\r\n\r\n</div>",
