  "html": "<div style=\"font-family:Inter,-apple-system,BlinkMacSystemFont,sans-serif;max-width:600px;margin:0 auto;background:#ffffff\">\r\n\r\n  <!-- Header -->\r\n  <div style=\"background:#1A1A1A;padding:1.5rem 2rem;display:flex;align-items:center;justify-content:space-between\">\r\n    <img src=\"/files/logo.png\" height=\"36\" alt=\"MatXchange\" style=\"display:block\">\r\n    <div style=\"text-align:right\">\r\n      <div style=\"color:#ffffff;font-size:12px;font-weight:600;letter-spacing:0.05em;text-transform:uppercase\">Waste Collection Receipt</div>\r\n      <div style=\"color:#888;font-size:11px;margin-top:2px\">matxchange.co.ke</div>\r\n    </div>\r\n  </div>\r\n\r\n  <!-- Transaction ID + Date bar -->\r\n  <div style=\"background:#F5F5F0;padding:0.75rem 2rem;display:flex;justify-content:space-between;align-items:center;border-bottom:1px solid #E8E8E4\">\r\n    <div style=\"font-size:13px;font-weight:700;color:#111\">{{ doc.name }}</div>\r\n    <div style=\"font-size:12px;color:#666\">{{ doc.transaction_date }}</div>\r\n  </div>\r\n\r\n  <!-- Body -->\r\n  <div style=\"padding:1.5rem 2rem\">\r\n\r\n    <!-- Parties -->\r\n    <div style=\"margin-bottom:1.5rem\">\r\n      <div style=\"font-size:10px;font-weight:600;color:#999;text-transform:uppercase;letter-spacing:0.08em;margin-bottom:0.6rem\">Parties</div>\r\n      <table style=\"width:100%;font-size:13px;border-collapse:collapse\">\r\n        <tr>\r\n          <td style=\"color:#666;padding:5px 0;width:40%\">Picker</td>\r\n          <td style=\"color:#111;font-weight:500;padding:5px 0\">{{ doc.picker }}</td>\r\n        </tr>\r\n        <tr>\r\n          <td style=\"color:#666;padding:5px 0\">Collector</td>\r\n          <td style=\"color:#111;font-weight:500;padding:5px 0\">{{ doc.collector or \"—\" }}</td>\r\n        </tr>\r\n        <tr>\r\n          <td style=\"color:#666;padding:5px 0\">Recycler</td>\r\n          <td style=\"color:#111;font-weight:500;padding:5px 0\">{{ doc.recycler or \"—\" }}</td>\r\n        </tr>\r\n      </table>\r\n    </div>\r\n\r\n    <div style=\"border-top:1px solid #F0F0EC;margin-bottom:1.5rem\"></div>\r\n\r\n    <!-- Material -->\r\n    <div style=\"margin-bottom:1.5rem\">\r\n      <div style=\"font-size:10px;font-weight:600;color:#999;text-transform:uppercase;letter-spacing:0.08em;margin-bottom:0.6rem\">Material</div>\r\n      <table style=\"width:100%;font-size:13px;border-collapse:collapse\">\r\n        <tr>\r\n          <td style=\"color:#666;padding:5px 0;width:40%\">Category</td>\r\n          <td style=\"color:#111;font-weight:500;padding:5px 0\">{{ doc.waste_category }}</td>\r\n        </tr>\r\n        <tr>\r\n          <td style=\"color:#666;padding:5px 0\">Weight</td>\r\n          <td style=\"color:#111;font-weight:500;padding:5px 0\">{{ doc.quantity_kg }} kg</td>\r\n        </tr>\r\n        <tr>\r\n          <td style=\"color:#666;padding:5px 0\">Unit price</td>\r\n          <td style=\"color:#111;font-weight:500;padding:5px 0\">KES {{ doc.unit_price_kes }} / kg</td>\r\n        </tr>\r\n      </table>\r\n    </div>\r\n\r\n    <div style=\"border-top:1px solid #F0F0EC;margin-bottom:1.5rem\"></div>\r\n\r\n    <!-- Payment -->\r\n    <div style=\"margin-bottom:1.5rem\">\r\n      <div style=\"font-size:10px;font-weight:600;color:#999;text-transform:uppercase;letter-spacing:0.08em;margin-bottom:0.6rem\">Payment</div>\r\n      <table style=\"width:100%;font-size:13px;border-collapse:collapse\">\r\n        <tr>\r\n          <td style=\"color:#666;padding:5px 0;width:40%\">Method</td>\r\n          <td style=\"color:#111;font-weight:500;padding:5px 0\">{{ doc.payment_method }}</td>\r\n        </tr>\r\n        <tr>\r\n          <td style=\"color:#666;padding:5px 0\">Status</td>\r\n          <td style=\"color:#111;font-weight:500;padding:5px 0\">{{ doc.payment_status }}</td>\r\n        </tr>\r\n        {% if doc.payment_reference %}\r\n        <tr>\r\n          <td style=\"color:#666;padding:5px 0\">Reference</td>\r\n          <td style=\"color:#111;font-weight:500;padding:5px 0\">{{ doc.payment_reference }}</td>\r\n        </tr>\r\n        {% endif %}\r\n      </table>\r\n    </div>\r\n\r\n    <!-- Total -->\r\n    <div style=\"background:#1A1A1A;border-radius:8px;padding:1rem 1.25rem;display:flex;justify-content:space-between;align-items:center;margin-bottom:1.5rem\">\r\n      <div style=\"color:#999;font-size:12px;font-weight:500;text-transform:uppercase;letter-spacing:0.05em\">Total Amount</div>\r\n      <div style=\"color:#ffffff;font-size:1.25rem;font-weight:700\">KES {{ doc.total_amount_kes }}</div>\r\n    </div>\r\n\r\n    <!-- Stellar -->\r\n    {% if doc.stellar_hash %}\r\n    <div style=\"border:1px solid #E8E8E4;border-radius:6px;padding:0.85rem 1rem;margin-bottom:1.5rem\">\r\n      <div style=\"font-size:10px;font-weight:600;color:#999;text-transform:uppercase;letter-spacing:0.08em;margin-bottom:4px\">Blockchain Verification</div>\r\n      <div style=\"font-size:11px;color:#444;word-break:break-all;font-family:monospace\">{{ doc.stellar_hash }}</div>\r\n    </div>\r\n    {% endif %}\r\n\r\n  </div>\r\n\r\n  <!-- Footer -->\r\n  <div style=\"border-top:1px solid #F0F0EC;padding:1rem 2rem;text-align:center\">\r\n    <div style=\"font-size:11px;color:#999\">Official MatXchange receipt · matxchange.co.ke</div>\r\n  </div>\r\n\r\n</div>",
