  "html": "<style>\r\n@import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=EB+Garamond:wght@400;600;700&display=swap');\r\n.cert-wrap{font-family:'EB Garamond',Georgia,serif;max-width:680px;margin:0 auto;background:#fff;border:10px solid #1A1A1A;position:relative}\r\n.cert-inner{border:2px solid #C8932A;margin:5px;position:relative;overflow:hidden}\r\n.cert-wm{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%) rotate(-35deg);font-size:85px;font-weight:900;color:rgba(200,147,42,0.055);pointer-events:none;white-space:nowrap;font-family:'Inter',sans-serif;letter-spacing:0.1em;z-index:0;user-select:none}\r\n.cert-corner{position:absolute;width:36px;height:36px;border-color:#C8932A;border-style:solid;z-index:2}\r\n.tl{top:10px;left:10px;border-width:2px 0 0 2px}\r\n.tr{top:10px;right:10px;border-width:2px 2px 0 0}\r\n.bl{bottom:10px;left:10px;border-width:0 0 2px 2px}\r\n.br{bottom:10px;right:10px;border-width:0 2px 2px 0}\r\n.cert-z{position:relative;z-index:1}\r\n.c-header{background:#1A1A1A;padding:16px 28px;display:flex;align-items:center;justify-content:space-between}\r\n.gold-bar{height:4px;background:#C8932A}\r\n.auth-bar{background:#FFFBF4;border-bottom:1px solid #E8D99A;padding:8px 28px;display:flex;align-items:center;justify-content:space-between}\r\n.seal{width:50px;height:50px;border-radius:50%;border:2px solid #C8932A;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;flex-shrink:0}\r\n.c-body{padding:20px 32px 16px}\r\n.c-table{width:100%;border-collapse:collapse;font-family:'Inter',sans-serif;font-size:11px;margin-bottom:12px}\r\n.c-table td{padding:7px 10px;border:1px solid #E0E0DC}\r\n.c-lbl{background:#F9F9F7;color:#666;font-weight:500;width:22%}\r\n.c-val{color:#111;font-weight:600;width:28%}\r\n.chain-box{border:1px solid #E0E0DC;background:#FAFAF8;padding:9px 12px;margin-bottom:16px}\r\n.sig-row{display:flex;justify-content:space-between;margin-top:20px;padding:0 4px}\r\n.sig-col{text-align:center;width:30%}\r\n.sig-line{border-top:1px solid #1A1A1A;padding-top:5px;margin-top:32px}\r\n.c-footer{background:#1A1A1A;padding:9px 28px;text-align:center}\r\n@media print{.cert-wrap{border-width:8px}}\r\n</style>\r\n\r\n<div class=\"cert-wrap\">\r\n<div class=\"cert-inner\">\r\n<div class=\"cert-wm\">SAMPLE</div>\r\n<div class=\"cert-corner tl\"></div>\r\n<div class=\"cert-corner tr\"></div>\r\n<div class=\"cert-corner bl\"></div>\r\n<div class=\"cert-corner br\"></div>\r\n<div class=\"cert-z\">\r\n\r\n<div class=\"c-header\">\r\n  <div style=\"display:flex;align-items:center;gap:10px\">\r\n    <img src=\"/files/logo.png\" height=\"40\" alt=\"MatXchange\" style=\"display:block\">\r\n    <div>\r\n      <div style=\"color:#fff;font-size:15px;font-weight:700;font-family:'EB Garamond',Georgia,serif\">MatXchange Ltd</div>\r\n      <div style=\"color:#C8932A;font-size:8px;letter-spacing:0.15em;text-transform:uppercase;font-family:'Inter',sans-serif;margin-top:2px\">Circular Economy Platform · Nairobi, Kenya</div>\r\n    </div>\r\n  </div>\r\n  <div style=\"text-align:right\">\r\n    <div style=\"color:#C8932A;font-size:8px;letter-spacing:0.12em;text-transform:uppercase;font-family:'Inter',sans-serif\">NEMA Accredited</div>\r\n    <div style=\"color:#888;font-size:8px;font-family:'Inter',sans-serif;margin-top:2px\">matxchange.co.ke</div>\r\n  </div>\r\n</div>\r\n\r\n<div class=\"gold-bar\"></div>\r\n\r\n<div class=\"auth-bar\">\r\n  <div class=\"seal\"><div style=\"font-size:7px;color:#C8932A;font-family:'Inter',sans-serif;font-weight:700;text-transform:uppercase;line-height:1.3\">Govt<br>Kenya</div></div>\r\n  <div style=\"text-align:center\">\r\n    <div style=\"font-size:8px;color:#666;font-family:'Inter',sans-serif;letter-spacing:0.1em;text-transform:uppercase;font-weight:600\">Republic of Kenya · Ministry of Environment, Climate Change &amp; Forestry</div>\r\n    <div style=\"font-size:8px;color:#888;font-family:'Inter',sans-serif;margin-top:2px\">Environmental Management and Coordination Act, Cap 387 · EPR Regulations 2021</div>\r\n  </div>\r\n  <div class=\"seal\"><div style=\"font-size:7px;color:#C8932A;font-family:'Inter',sans-serif;font-weight:700;text-transform:uppercase;line-height:1.3;text-align:center\">NEMA<br>KE</div></div>\r\n</div>\r\n\r\n<div class=\"c-body\">\r\n\r\n  <div style=\"text-align:center;margin-bottom:14px\">\r\n    <div style=\"font-size:8px;letter-spacing:0.2em;text-transform:uppercase;color:#888;font-family:'Inter',sans-serif;margin-bottom:5px\">Extended Producer Responsibility</div>\r\n    <div style=\"font-size:24px;font-weight:700;color:#1A1A1A\">Certificate of Compliance</div>\r\n    <div style=\"width:44px;height:2px;background:#C8932A;margin:7px auto 0\"></div>\r\n  </div>\r\n\r\n  <div style=\"text-align:center;margin-bottom:12px\">\r\n    <span style=\"font-family:'Inter',sans-serif;font-size:8px;color:#888;letter-spacing:0.08em;text-transform:uppercase\">Certificate No. </span>\r\n    <span style=\"font-family:monospace;font-size:11px;color:#1A1A1A;font-weight:700\">{{ doc.name }}</span>\r\n    <span style=\"font-family:'Inter',sans-serif;font-size:8px;color:#888;margin-left:14px\">Issued: {{ doc.issue_date }}</span>\r\n  </div>\r\n\r\n  <div style=\"text-align:center;padding:0 20px;margin-bottom:14px\">\r\n    <p style=\"font-size:12px;color:#555;margin:0 0 5px;font-style:italic\">This is to certify that</p>\r\n    <div style=\"font-size:19px;font-weight:700;color:#1A1A1A;border-bottom:1px solid #C8932A;display:inline-block;padding-bottom:3px;margin-bottom:8px\">{{ doc.producer }}</div>\r\n    <p style=\"font-size:12px;color:#444;line-height:1.6;margin:0\">has fulfilled its Extended Producer Responsibility obligations under the<br>\r\n    <strong style=\"color:#1A1A1A\">Environmental Management and Coordination Act, Cap 387</strong><br>\r\n    by verifiably diverting</p>\r\n  </div>\r\n\r\n  <div style=\"text-align:center;margin:12px 0\">\r\n    <div style=\"font-size:50px;font-weight:700;color:#1A1A1A;letter-spacing:-2px;line-height:1;font-family:'EB Garamond',Georgia,serif\">{{ doc.waste_offset_kg }} <span style=\"font-size:20px;font-weight:400;color:#888\">kg</span></div>\r\n    <div style=\"font-size:9px;color:#888;font-family:'Inter',sans-serif;margin-top:4px;text-transform:uppercase;letter-spacing:0.1em\">of post-consumer waste from landfill</div>\r\n  </div>\r\n\r\n  <div style=\"font-size:11px;color:#555;text-align:center;margin-bottom:16px;font-style:italic\">through the MatXchange circular economy platform, Nairobi, Kenya</div>\r\n\r\n  <hr style=\"border:none;border-top:1px solid #E8E8E4;margin:12px 0\">\r\n\r\n  <table class=\"c-table\">\r\n    <tr>\r\n      <td class=\"c-lbl\">Waste category</td>\r\n      <td class=\"c-val\">{{ doc.waste_category or \"—\" }}</td>\r\n      <td class=\"c-lbl\">Certified recycler</td>\r\n      <td class=\"c-val\">{{ doc.recycler }}</td>\r\n    </tr>\r\n    <tr>\r\n      <td class=\"c-lbl\">Material batch</td>\r\n      <td class=\"c-val\">{{ doc.material_batch or \"—\" }}</td>\r\n      <td class=\"c-lbl\">NEMA reg. no.</td>\r\n      <td class=\"c-val\">{{ doc.nema_reg_number or \"—\" }}</td>\r\n    </tr>\r\n    <tr>\r\n      <td class=\"c-lbl\">Issue date</td>\r\n      <td class=\"c-val\">{{ doc.issue_date }}</td>\r\n      <td class=\"c-lbl\">Expiry date</td>\r\n      <td class=\"c-val\">{{ doc.expiry_date }}</td>\r\n    </tr>\r\n    <tr>\r\n      <td class=\"c-lbl\">Status</td>\r\n      <td class=\"c-val\" style=\"color:#1A1A1A;font-weight:700\">{{ doc.status }}</td>\r\n      <td class=\"c-lbl\">CO&#8322; offset est.</td>\r\n      <td class=\"c-val\">{{ (doc.waste_offset_kg * 2.5)|round(1) }} tonnes</td>\r\n    </tr>\r\n  </table>\r\n\r\n  {% if doc.stellar_hash %}\r\n  <div class=\"chain-box\">\r\n    <div style=\"font-family:'Inter',sans-serif;font-size:8px;font-weight:700;color:#666;text-transform:uppercase;letter-spacing:0.1em;margin-bottom:3px\">Stellar Blockchain Verification — Immutable On-Chain Record</div>\r\n    <div style=\"font-family:monospace;font-size:9px;color:#333;word-break:break-all\">{{ doc.stellar_hash }}</div>\r\n    <div style=\"font-family:'Inter',sans-serif;font-size:8px;color:#888;margin-top:3px\">Verify: stellar.expert/explorer/testnet/tx/{{ doc.stellar_hash }}</div>\r\n  </div>\r\n  {% endif %}\r\n\r\n  <div class=\"sig-row\">\r\n    <div class=\"sig-col\">\r\n      <div class=\"sig-line\">\r\n        <div style=\"font-family:'Inter',sans-serif;font-size:9px;color:#333;font-weight:600\">Producer Representative</div>\r\n        <div style=\"font-family:'Inter',sans-serif;font-size:8px;color:#888;margin-top:1px\">{{ doc.producer }}</div>\r\n        <div style=\"font-family:'Inter',sans-serif;font-size:8px;color:#888\">Date: _______________</div>\r\n      </div>\r\n    </div>\r\n    <div class=\"sig-col\">\r\n      <div style=\"width:48px;height:48px;border-radius:50%;border:2px solid #C8932A;margin:0 auto 3px;display:flex;align-items:center;justify-content:center\">\r\n        <div style=\"font-size:7px;color:#C8932A;font-family:'Inter',sans-serif;font-weight:700;text-align:center;text-transform:uppercase;line-height:1.3\">MX<br>Seal</div>\r\n      </div>\r\n      <div class=\"sig-line\">\r\n        <div style=\"font-family:'Inter',sans-serif;font-size:9px;color:#333;font-weight:600\">MatXchange Ltd</div>\r\n        <div style=\"font-family:'Inter',sans-serif;font-size:8px;color:#888\">Authorised Signatory</div>\r\n        <div style=\"font-family:'Inter',sans-serif;font-size:8px;color:#888\">Date: {{ doc.issue_date }}</div>\r\n      </div>\r\n    </div>\r\n    <div class=\"sig-col\">\r\n      <div class=\"sig-line\">\r\n        <div style=\"font-family:'Inter',sans-serif;font-size:9px;color:#333;font-weight:600\">NEMA Representative</div>\r\n        <div style=\"font-family:'Inter',sans-serif;font-size:8px;color:#888\">National Environment Authority</div>\r\n        <div style=\"font-family:'Inter',sans-serif;font-size:8px;color:#888\">Date: _______________</div>\r\n      </div>\r\n    </div>\r\n  </div>\r\n\r\n  <div style=\"margin-top:16px;padding-top:10px;border-top:1px solid #E8E8E4;font-family:'Inter',sans-serif;font-size:8px;color:#999;line-height:1.6;text-align:center\">\r\n    This certificate is issued under the Environmental Management and Coordination (Extended Producer Responsibility) Regulations, 2021.<br>\r\n    It is a legally binding document. Do not alter, reproduce, or transfer without written authorisation from MatXchange Ltd.<br>\r\n    To verify authenticity visit matxchange.co.ke or check the Stellar blockchain hash above.\r\n  </div>\r\n\r\n</div>\r\n\r\n<div class=\"c-footer\">\r\n  <div style=\"color:#888;font-size:8px;font-family:'Inter',sans-serif;letter-spacing:0.05em\">MatXchange Ltd · Nairobi, Kenya · matxchange.co.ke · samuel@thematxchange.com · The operating system for Africa's circular economy</div>\r\n</div>\r\n\r\n</div>\r\n</div>\r\n</div>",
